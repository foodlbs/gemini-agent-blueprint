#!/usr/bin/env bash
# Deploy the AI release pipeline to Vertex AI Agent Engine.
#
# Usage:
#   GOOGLE_CLOUD_PROJECT=my-proj GOOGLE_CLOUD_LOCATION=us-central1 \
#       AGENT_ENGINE_SA=ai-release-pipeline@my-proj.iam.gserviceaccount.com \
#       bash deploy/deploy.sh
#
# Outputs the Reasoning Engine resource ID (reasoningEngines/NNNNN) which
# the Cloud Function trigger needs (set as TF_VAR_agent_engine_resource_id
# before applying deploy/scheduler.tf).

set -euo pipefail

: "${GOOGLE_CLOUD_PROJECT:?Set GOOGLE_CLOUD_PROJECT}"
: "${GOOGLE_CLOUD_LOCATION:?Set GOOGLE_CLOUD_LOCATION (e.g., us-central1)}"

DISPLAY_NAME="${DISPLAY_NAME:-ai-release-pipeline}"
DESCRIPTION="${DESCRIPTION:-Polling multi-agent content pipeline for AI releases (DESIGN.md)}"
AGENT_DIR="${AGENT_DIR:-pipeline}"

# Service account that the deployed Agent Engine runs as. Defaults to the
# convention used by deploy/secrets.tf for IAM grants.
AGENT_ENGINE_SA="${AGENT_ENGINE_SA:-ai-release-pipeline@${GOOGLE_CLOUD_PROJECT}.iam.gserviceaccount.com}"

echo "================================================================"
echo "Deploying AI release pipeline to Vertex AI Agent Engine"
echo "  project:         ${GOOGLE_CLOUD_PROJECT}"
echo "  region:          ${GOOGLE_CLOUD_LOCATION}"
echo "  display name:    ${DISPLAY_NAME}"
echo "  agent dir:       ${AGENT_DIR}"
echo "  service account: ${AGENT_ENGINE_SA}"
echo "================================================================"

# Capture stdout to extract the resource ID. ADK prints
# "AgentEngine resource_name: projects/.../reasoningEngines/NNN" on success.
DEPLOY_LOG="$(mktemp)"
trap 'rm -f "${DEPLOY_LOG}"' EXIT

uv run adk deploy agent_engine \
    --project="${GOOGLE_CLOUD_PROJECT}" \
    --region="${GOOGLE_CLOUD_LOCATION}" \
    --display_name="${DISPLAY_NAME}" \
    --description="${DESCRIPTION}" \
    --adk_app=agent.py \
    --adk_app_object=root_agent \
    --trace_to_cloud \
    --otel_to_cloud \
    "${AGENT_DIR}" 2>&1 | tee "${DEPLOY_LOG}"

# Pull the resource ID out of the deploy log. Format:
#   projects/<num>/locations/<region>/reasoningEngines/<id>
RESOURCE_NAME=$(grep -oE "projects/[^/]+/locations/[^/]+/reasoningEngines/[0-9]+" "${DEPLOY_LOG}" | tail -1 || true)
RESOURCE_ID=$(echo "${RESOURCE_NAME}" | grep -oE "reasoningEngines/[0-9]+" | tail -1 || true)

if [[ -z "${RESOURCE_ID}" ]]; then
    echo "ERROR: failed to extract reasoningEngines resource ID from deploy output." >&2
    echo "       Inspect the log and set AGENT_ENGINE_RESOURCE_ID manually before applying scheduler.tf." >&2
    exit 1
fi

echo
echo "Deployment complete."
echo "  Resource name: ${RESOURCE_NAME}"
echo "  Resource ID:   ${RESOURCE_ID}"
echo
echo "Next steps:"
echo "  1. (one-time) gcloud beta ai reasoning-engines update '${RESOURCE_NAME}' \\"
echo "         --service-account='${AGENT_ENGINE_SA}'"
echo "  2. cd deploy && terraform apply \\"
echo "         -var=agent_engine_resource_id='${RESOURCE_ID}' \\"
echo "         -var=agent_engine_sa_email='${AGENT_ENGINE_SA}' \\"
echo "         -var=google_cloud_project='${GOOGLE_CLOUD_PROJECT}' \\"
echo "         -var=google_cloud_location='${GOOGLE_CLOUD_LOCATION}'"
echo "  3. gcloud scheduler jobs run ai-release-pipeline-hourly \\"
echo "         --location='${GOOGLE_CLOUD_LOCATION}'"

# Persist the resource ID for downstream tooling.
echo "${RESOURCE_ID}" > deploy/.last_resource_id
