# Secret Manager secrets for the pipeline runtime.
#
# DESIGN.md "Tools to implement" lists two secrets:
#   - GitHub PAT (used by github_ops read + write wrappers).
#   - Telegram bot token (used by telegram_post_topic_for_approval and
#     telegram_post_for_approval).
#
# Set the values via TF_VAR_github_token and TF_VAR_telegram_bot_token
# environment variables before `terraform apply`. Never commit these to
# source control.

variable "github_token" {
  type        = string
  description = "GitHub Personal Access Token. Pass via TF_VAR_github_token; never commit."
  sensitive   = true
}

variable "telegram_bot_token" {
  type        = string
  description = "Telegram bot token. Pass via TF_VAR_telegram_bot_token; never commit."
  sensitive   = true
}

variable "agent_engine_sa_email" {
  type        = string
  description = "Service account email used by the deployed Agent Engine (set this AFTER deploy.sh runs)."
}

# --- GitHub PAT ------------------------------------------------------------

resource "google_secret_manager_secret" "github_token" {
  secret_id = "ai-release-pipeline-github-token"
  replication {
    auto {}
  }
}

resource "google_secret_manager_secret_version" "github_token" {
  secret      = google_secret_manager_secret.github_token.id
  secret_data = var.github_token
}

resource "google_secret_manager_secret_iam_member" "github_token_accessor" {
  secret_id = google_secret_manager_secret.github_token.id
  role      = "roles/secretmanager.secretAccessor"
  member    = "serviceAccount:${var.agent_engine_sa_email}"
}

# --- Telegram bot token ----------------------------------------------------

resource "google_secret_manager_secret" "telegram_bot_token" {
  secret_id = "ai-release-pipeline-telegram-bot-token"
  replication {
    auto {}
  }
}

resource "google_secret_manager_secret_version" "telegram_bot_token" {
  secret      = google_secret_manager_secret.telegram_bot_token.id
  secret_data = var.telegram_bot_token
}

resource "google_secret_manager_secret_iam_member" "telegram_bot_token_accessor" {
  secret_id = google_secret_manager_secret.telegram_bot_token.id
  role      = "roles/secretmanager.secretAccessor"
  member    = "serviceAccount:${var.agent_engine_sa_email}"
}

# --- Outputs ---------------------------------------------------------------

output "github_token_secret_id" {
  description = "Reference this in the Agent Engine env: GITHUB_TOKEN_SECRET=<this>"
  value       = google_secret_manager_secret.github_token.secret_id
}

output "telegram_bot_token_secret_id" {
  description = "Reference this in the Agent Engine env: TELEGRAM_BOT_TOKEN_SECRET=<this>"
  value       = google_secret_manager_secret.telegram_bot_token.secret_id
}
