# Terraform local state — committing it leaks IAM bindings and would
# create state-management conflicts between operators.
*.tfstate
*.tfstate.*
*.tfstate.backup

# Provider plugins + module cache (regenerated by `terraform init`).
.terraform/
# NOTE: .terraform.lock.hcl IS committed — it pins provider versions
# so all operators install the same plugins. Do NOT gitignore it.

# Plan output captured by `terraform plan -out=...`.
*.tfplan

# Operator's local var values — pass via TF_VAR_* env or
# `terraform apply -var=` instead of committing a .tfvars file.
*.tfvars
*.auto.tfvars
